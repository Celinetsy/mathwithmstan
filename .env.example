# Copy to .env.local for local dev. In production, set these in Cloudflare Pages
# (for the frontend) and Vercel (for the api/ routes) instead.

# --- Frontend (Cloudflare Pages) ---
# Public values, safe to expose to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: base URL of the Vercel api/ deployment, if you call api/hello etc.
# Leave blank if the frontend does not call any Vercel functions.
VITE_API_BASE=https://YOUR-VERCEL-DEPLOYMENT.vercel.app

# --- Backend (Vercel api/) ---
# SECRET. Never expose the service_role key to the browser or commit real values.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET
ALLOWED_ORIGIN=https://YOUR-CLOUDFLARE-PAGES-DOMAIN
